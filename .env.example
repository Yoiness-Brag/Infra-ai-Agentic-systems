# infra-code MVP — environment contract (SPEC §6).
# Copy to `.env` and fill REAL values. `.env` is gitignored and NEVER committed.
# `make` reads these and injects them into K8s Secrets at bootstrap (env -> Secret).

# Google AI Studio / Gemini API key. Used by:
#   - kagent ModelConfig (gemini-2.5-flash, via Kong ai-proxy-advanced)
#   - mcp-graphiti-memory (Graphiti Gemini embedder embedding-001)
#   - eval/run_eval.py (Gemini LLM-as-judge)
# REQUIRED. Services fail-closed if empty.
GOOGLE_API_KEY=

# Shared HS256 JWT secret. Used by Kong jwt plugin (consumer mvp-app) AND agent-backend
# re-verification (iss=mvp-app). `make token` mints a test JWT signed with this.
# REQUIRED, fail-closed. Use a long random string, e.g.: openssl rand -hex 32
JWT_SECRET=

# Postgres password for user `agent`, db `agentmvp` (sessions table). REQUIRED, fail-closed.
POSTGRES_PASSWORD=

# FalkorDB password (--requirepass). OPTIONAL for the MVP — leave empty to run FalkorDB
# without auth; set to enforce a password on the Graphiti backend.
FALKORDB_PASSWORD=
